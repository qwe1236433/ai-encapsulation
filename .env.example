# 复制此文件为 `.env` 后按需修改（与 docker-compose.yml 同级目录）
# PowerShell: Copy-Item .env.example .env

# ----- 项目内服务发现（容器之间，一般保持默认即可） -----
HERMES_INTERNAL_URL=http://hermes:8080
OPENCLAW_INTERNAL_URL=http://openclaw:3000

# ----- 宿主机端口映射 -----
HERMES_HOST_PORT=8080
OPENCLAW_HOST_PORT=3000

# ----- Windows 宿主机路径（正斜杠）；换机器时改这里 -----
HERMES_CONFIG_FILE=D:/ai封装/hermes/config.yaml
HERMES_SESSIONS_DIR=D:/ai封装/hermes/sessions
OPENCLAW_CONFIG_FILE=D:/ai封装/openclaw/config.yaml
OPENCLAW_DATA_DIR=D:/ai封装/openclaw/data

# ----- Sprint 2: Ollama（宿主机运行；容器内用 host.docker.internal）-----
OLLAMA_HOST=http://host.docker.internal:11434
# 与宿主机 ollama list 一致（例：gemma4:latest）
HERMES_MODEL=gemma4:latest
# 主模型 404 时按顺序尝试
HERMES_MODEL_FALLBACK=gemma2:latest,llama3.2:latest
HERMES_LLM_ENABLED=true
HERMES_OLLAMA_TIMEOUT_SEC=120
HERMES_TAVC_MAX_ATTEMPTS=3
# 容器内轨迹目录（与 compose 挂载的 sessions 对齐）
HERMES_SESSIONS_DIR=/app/sessions

# Verify：always=启发式软审通过后必调 Ollama；never=不调；if_soft=仅当 HERMES_SOFT_VERIFY_ENABLED时调
HERMES_LLM_VERIFY_MODE=always
HERMES_VERIFY_DOUBT_LOW=0.12
HERMES_VERIFY_DOUBT_HIGH=0.88

# Hermes / uvicorn 子 logger（根日志仍由 uvicorn 控制）
LOG_LEVEL=INFO

# OpenClaw 注入随机坏读数，用于压测 Verify/Correct（默认关）
OPENCLAW_SIMULATE_NOISE=false
OPENCLAW_SIMULATE_FAILURE_RATE=0.25

# 流量模拟（Hermes S3 与 OpenClaw 共用同名环境变量；PASS_MIN 仅 Hermes 校验用）
TRAFFIC_SIM_BOOST_KEYWORD=救命
TRAFFIC_SIM_LIKES_IF_HIT=1000
TRAFFIC_SIM_LIKES_ELSE=10
TRAFFIC_SIM_PASS_MIN=500
# 硬指标 CTR(%) 下限；设为 off 关闭 CTR 门槛
TRAFFIC_SIM_CTR_PASS_MIN=3.0

# S3：是否用「目标措辞 vs 趋势方向」做主观对齐（默认关，尽量只信数据）
HERMES_VERIFY_GOAL_ALIGNMENT=false
# S4：ε-greedy 探索概率（优先于 HERMES_CORRECT_PIVOT_PROB）；未设置时回退到 PIVOT_PROB
HERMES_EXPLORE_EPSILON=0.25
HERMES_CORRECT_PIVOT_PROB=0.35
# S3软指标（钩子行等）额外审查，默认关
HERMES_SOFT_VERIFY_ENABLED=false

# 案例库抗认知漂移：软衰减 Weight=1/(1+alpha*Δ小时)；MAX_AGE_HOURS=0 表示不硬截断
CASE_LIBRARY_DECAY_ALPHA=0.04
CASE_LIBRARY_MAX_AGE_HOURS=0
# 同一 market fingerprint 下引用案例后 Verify 连续失败达到阈值 → 案例 deprecated，可选写入负样本池；S4 强制探索
CASE_CONFLICT_FAIL_THRESHOLD=3
CASE_DEPRECATE_TO_NEGATIVE_POOL=true
# 指纹：strict=哈希全等；fuzzy=风格标签 Jaccard≥阈值（更易累计 streak）。可选要求爆词一致：
# CASE_FINGERPRINT_REQUIRE_KEYWORD_MATCH=true
CASE_FINGERPRINT_MATCH_MODE=fuzzy
CASE_FINGERPRINT_JACCARD_MIN=0.7
# S4 认知冲突后跳跃式修正（大幅改参 / 换策略向）
HERMES_CONFLICT_JUMP_ENABLED=true
HERMES_CONFLICT_JUMP_STRENGTH=0.5
# 负样本失败等级：灾难性失败更久封杀、更低复活概率；轻微失败相反（倍数可微调）
# HERMES_NEGATIVE_SEV_CATASTROPHE_ROUND_MULT=3.0
# HERMES_NEGATIVE_SEV_MILD_ROUND_MULT=0.55
# HERMES_NEGATIVE_SEV_CATASTROPHE_RETRY_MULT=0.25
# HERMES_NEGATIVE_SEV_MILD_RETRY_MULT=2.0

# Score：默认对数刻度（倍率增量更可比）；linear 关闭
TRAFFIC_SCORE_USE_LOG=true
# TRAFFIC_SCORE_LOG_CEIL_LIKES=8000
# TRAFFIC_SCORE_LOG_FLOOR_CTR=0.15
# TRAFFIC_SCORE_LOG_CEIL_CTR=12.0

# S4 负样本池：硬指标失败时记录 action+params，Correct 时尽量避开
HERMES_NEGATIVE_POOL_ENABLED=true
HERMES_NEGATIVE_POOL_MAX=64
# 半衰期：超过 N 轮未再被 hard_fail 强化 → 高风险区，以 HERMES_NEGATIVE_SOFT_RETRY_PROB 概率放行重试
HERMES_NEGATIVE_POOL_DECAY_ROUNDS=12
HERMES_NEGATIVE_SOFT_RETRY_PROB=0.01
# 可选：按墙上时钟半衰（秒），与 DECAY_ROUNDS 二选一或同时满足任一即视为 stale
HERMES_NEGATIVE_POOL_DECAY_SEC=0

# Phase 2（可选）：动态封杀 / 动态复活率（默认关闭，先跑 Phase 1 观测）
# HERMES_NEGATIVE_POOL_DYNAMIC_MODE=false
# HERMES_NEGATIVE_POOL_CONFIDENCE_THRESHOLD=0.95
# HERMES_NEGATIVE_POOL_EMPIRICAL_MIN_N=8
# HERMES_NEGATIVE_POOL_EXPLORATION_BUDGET=0.05

# 对数评分动态上沿：最近 K 次「成功 Verify」的 likes/ctr 分位数抬高 ceil，减轻后期全贴 0.99
TRAFFIC_SCORE_DYNAMIC_CEIL=true
TRAFFIC_SCORE_DYNAMIC_K=24
TRAFFIC_SCORE_DYNAMIC_MIN_N=4
TRAFFIC_SCORE_DYNAMIC_QUANTILE=0.9
TRAFFIC_SCORE_DYNAMIC_CEIL_MULT=1.12
TRAFFIC_SCORE_DYNAMIC_STATIC_WEIGHT=0.55

# OpenClaw 复合算子 publish_and_monitor：请求等待与上限（秒，防误睡 24h）
OPENCLAW_COMPOUND_WAIT_SEC=2
OPENCLAW_COMPOUND_WAIT_MAX_SEC=15
