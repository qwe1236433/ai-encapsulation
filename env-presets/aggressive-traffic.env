# 【激进探索型】抢首发 / 追热点 — 与仓库根目录 .env 或 .env.example 合并使用。
# PowerShell 示例：Get-Content .env, env-presets\aggressive-traffic.env | Set-Content .env.merged
# Docker：在 compose 中增加 env_file: - env-presets/aggressive-traffic.env

CASE_LIBRARY_DECAY_ALPHA=0.1
CASE_CONFLICT_FAIL_THRESHOLD=2
HERMES_EXPLORE_EPSILON=0.4
CASE_FINGERPRINT_MATCH_MODE=fuzzy
CASE_FINGERPRINT_JACCARD_MIN=0.7
